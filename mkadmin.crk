
import crack.ascii strip;
import crack.io cerr, cin;
import crack.io.readers LineReader;
import .data Data;

data := Data();
data.init();

input := LineReader(cin);
String prompt(String prompt) {
    cerr `\033[32;1m$prompt:\033[0m `;
    return strip(input.readLine());
}

user := prompt('User');
password := prompt('Password');

data.addUser(user, password);
