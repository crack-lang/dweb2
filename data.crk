## DWeb data layer.

import crack.cont.array Array;
import crack.fs makePath;
import crack.io Formatter;
import crack.hash.sha256 SHA256;
import crack.lang cmp, makeHashVal;
import kvjournal.db BFile;
import kvjournal.kvdb DBIFace, DBIter, Partition;
import crack.http.auth StupidRNG;
import crack.protobuf readMessageFromString, Field, Message, ProtoWriter;

import .authdb AuthDBImpl, UserPB;

@import crack.protobuf.ann protobuf;
@import crack.ann impl;

@protobuf {
    version = 1

    ## A URL and a descriptive string.
    message Bookmark {
        optional string desc = 1;
        optional string url = 2;
    }

    message Item {
        optional string name = 1;
        optional string order = 2;
        optional string qty = 3;   # yarrrrr...
        optional string units = 4;
        optional int32 flags = 5;
    }

    message ShoppingList {
        repeated Item items = 1;
    }
}

## Selected means that the item is checked in a normal list, in a template it
## means that that the item is "non-optional" (i.e. should be present in every
## generated shopping list)
const FLAG_SELECTED := 1;

## Iterator for objects in which the value is a Message type.
class Iter[T] {

    DBIter cur;

    oper init(DBIter iter) : cur = iter {}

    T elem() {
        T obj = {};
        readMessageFromString(obj, cur.elem().val);
        return obj;
    }

    void next() { cur.next() }
    bool isTrue() { return cur.elem() }
    Iter iter() { return this }
}

## Contains all of the data objects and methods to access them.
class Data {
    DBIFace users, cookies;
    AuthDBImpl auth;
    StupidRNG rng;

    ## General database.
    DBIFace general;

    void init() {
        # Read and hash the salt file.
        src := makePath('server_salt.data').reader();
        hasher := SHA256();
        while (buf := src.read(1024))
            hasher.update(buf);
        digest := hasher.digest();

        users = BFile.makeFile(makePath('users.db'));
        cookies = BFile.makeFile(makePath('cookies.db'));

        rng = StupidRNG(array[uint64](digest.buffer)[0],
                        array[uint64](digest.buffer + 8)[0]
                        );

        auth = AuthDBImpl(rng, users, cookies );

        # Make the general database.
        general = BFile.makeFile(makePath('general.db'));
    }

    ## Adds a user.
    void addUser(String user, String password) {
        auth.addUser(user, password, rng());
    }

    ## Delete the user.  This currently doesn't clean up all of the user's
    ## bookmarks, so it's kind of a security hole.
    void deleteUser(String userId) {
        users.delete(userId);
    }

    ## Adds a bookmark record for a user.
    void addBookmark(String user, String desc, String url) {
        bookmark := Bookmark();
        bookmark.desc = desc;
        bookmark.url = url;
        general[user + '/' + desc] = bookmark.toString();
        general.commit();
    }

    ## Get all bookmarks for the user.
    Partition getBookmarks(String user) {
        return Partition(general, user + '/');
    }

    ## Iterate over users in order by id.
    Iter[UserPB] iterUsers() {
        return Iter[UserPB](users.iter());
    }

    ## Get the shopping list.
    ShoppingList getList(String name) {
        path := makePath('lists')/name;
        if (path.exists()) {
            list := ShoppingList();
            readMessageFromString(list, path.readAll());
            return list;
        }
        return null;
    }

    ## Store a shopping list.
    void storeList(String name, ShoppingList list) {
        path := makePath('lists');
        path.makeDirs();
        (path/name).writeAll(list.toString());
    }

    ## Returns a list of all list names.
    Array[String] getLists() {
        result := Array[String]();
        for (child :in makePath('lists').children())
            result.append(child.getName());
        return result;
    }
}
