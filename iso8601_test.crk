
import crack.io cerr;
import unittest register, runAllTests, Test;
import .iso8601 ISODate, TS_RX;

@import crack.ann assert;
@import unittest_ann test;

@test(TimestampRX, {
    val := '2022-01-16T13:42:01-05:00';
    @assert(TS_RX.match(val));
    @assert(TS_RX.match(val).group() == val);
    @assert(TS_RX.match('2022-01-16T13:42:01+05:00'));
})

@test(ParsingAndRender, {
    val := '2022-01-16T13:42:01-05:00';
    @assert(ISODate.parse(val).toString() == val);
})

runAllTests();

